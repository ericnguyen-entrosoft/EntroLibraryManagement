<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Reject Wizard Form -->
    <record id="library_request_reject_wizard_view_form" model="ir.ui.view">
        <field name="name">library.request.reject.wizard.view.form</field>
        <field name="model">library.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối yêu cầu">
                <group>
                    <field name="request_id" invisible="1"/>
                    <field name="rejection_reason"
                        placeholder="Nhập lý do từ chối yêu cầu này. Nội dung sẽ được gửi cho người yêu cầu."/>
                </group>
                <footer>
                    <button string="Xác nhận từ chối"
                        name="action_confirm_reject"
                        type="object"
                        class="btn-primary"/>
                    <button string="Hủy"
                        class="btn-secondary"
                        special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
