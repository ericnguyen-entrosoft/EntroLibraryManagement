<odoo>
    <template id="favicon_icon" inherit_id="web.layout" name="Web layout">
        <xpath expr="//head/link[@rel='shortcut icon']" position="attributes">
            <attribute
                name="t-att-href"
            >env['res.company'].sudo()._get_favicon() or '/web/static/img/favicon.ico'</attribute>
        </xpath>
        <xpath expr="//link[@rel='shortcut icon']" position="after">
            <!-- iOS -->
            <link rel="apple-touch-icon" href="/web_favicon/static/src/img/icons/icon-180.png"/>
            <link rel="apple-touch-icon" sizes="180x180" href="/web_favicon/static/src/img/icons/icon-180.png"/>

            <!-- Android Chrome -->
            <link rel="icon" type="image/png" sizes="192x192" href="/web_favicon/static/src/img/icons/icon-192.png"/>
            <link rel="icon" type="image/png" sizes="512x512" href="/web_favicon/static/src/img/icons/icon-512.png"/>
            <link rel="manifest" href="/web_favicon/static/src/manifest.json"/>

            <!-- Android Chrome theme color -->
            <meta name="theme-color" content="#F2B885"/>
            <meta name="mobile-web-app-capable" content="yes"/>
        </xpath>
    </template>
</odoo>
